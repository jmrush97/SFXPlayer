      <AutoGen>True</AutoGen>
      <DependentUpon>SplashScreen.resx</DependentUpon>
    </Compile>
    <Compile Update="forms\TimeStamper.Designer.cs">
      <DesignTime>True</DesignTime>
      <AutoGen>True</AutoGen>
      <DependentUpon>TimeStamper.resx</DependentUpon>
    </Compile>
    <Compile Update="forms\ucVolume.cs">
      <SubType>UserControl</SubType>
    </Compile>
    <Compile Update="forms\ucSpeed.cs">
      <SubType>UserControl</SubType>
    </Compile>
    <Compile Update="forms\ucVolume.Designer.cs">
      <DesignTime>True</DesignTime>
