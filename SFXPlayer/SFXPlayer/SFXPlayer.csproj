    <EmbeddedResource Include="Resources\music-note-beamed.svg" />
    <Content Include="Resources\SFXPlayer282.png" />
    <Content Include="Resources\Stop.png" />
    <Content Include="Resources\SFXPlayer.PNG" />
    <Content Include="Resources\FXPlayer.ico" />
    <Content Include="Resources\Headphones.ico" />
    <Content Include="Resources\Pause.png" />
    <Content Include="Resources\Play.ico" />
  </ItemGroup>
  <ItemGroup>
    <BootstrapperPackage Include=".NETFramework,Version=v4.7.2">
      <Visible>False</Visible>
      <ProductName>Microsoft .NET Framework 4.7.2 %28x86 and x64%29</ProductName>
      <Install>true</Install>
    </BootstrapperPackage>
    <BootstrapperPackage Include="Microsoft.Net.Framework.3.5.SP1">
      <Visible>False</Visible>
      <ProductName>.NET Framework 3.5 SP1</ProductName>
      <Install>false</Install>
    </BootstrapperPackage>
  </ItemGroup>
  <ItemGroup>
    <FileAssociation Include=".sfx">
      <Visible>False</Visible>
      <Description>SFX Cue List</Description>
      <Progid>cues</Progid>
      <DefaultIcon>FXPlayer.ico</DefaultIcon>
    </FileAssociation>
    <FileAssociation Include=".show">
      <Visible>False</Visible>
      <Description>Compressed SFX Show Archive</Description>
      <Progid>show</Progid>
      <DefaultIcon>FXPlayer.ico</DefaultIcon>
    </FileAssociation>
  </ItemGroup>
  <ItemGroup>
    <Folder Include="html\bootstrap\" />
  </ItemGroup>
  <ItemGroup>
    <EmbeddedResource Update="forms\MSCEventEditor.resx">
      <Generator>PublicResXFileCodeGenerator</Generator>
      <LastGenOutput>MSCEventEditor.Designer.cs</LastGenOutput>
    </EmbeddedResource>
    <EmbeddedResource Update="forms\PlayStrip.resx">
      <Generator>PublicResXFileCodeGenerator</Generator>
      <LastGenOutput>PlayStrip.Designer.cs</LastGenOutput>
    </EmbeddedResource>
    <EmbeddedResource Update="forms\SFXPlayer.resx">
      <Generator>PublicResXFileCodeGenerator</Generator>
