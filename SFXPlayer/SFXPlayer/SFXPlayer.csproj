    </EmbeddedResource>
    <EmbeddedResource Update="ResourcesSvg.resx">
      <Generator>PublicResXFileCodeGenerator</Generator>
      <LastGenOutput>ResourcesSvg.Designer.cs</LastGenOutput>
    </EmbeddedResource>
